{
  "mt5-python-api": {
    "description": "MetaTrader5 Python lib quirks: filling modes, retcodes, init/shutdown.",
    "triggers": {
      "keywords": ["MetaTrader5", "mt5.", "order_send", "symbol_info", "copy_rates", "retcode", "filling_mode"],
      "keywordPatterns": ["\\bmt5\\.[a-z_]+\\b", "ORDER_FILLING_(?:FOK|IOC|RETURN)", "TRADE_RETCODE_"],
      "pathPatterns": ["src/mt5_mvp/(client|trade|market|account|constants)\\.py"],
      "intentPatterns": [
        "(initialise|initialize|connect).*MT5",
        "(filling|retcode|magic).*(broker|InstaForex)"
      ]
    },
    "excludePatterns": []
  },
  "mcp-fastmcp": {
    "description": "FastMCP tool decorators, transports, hints, instructions.",
    "triggers": {
      "keywords": ["FastMCP", "@mcp.tool", "MCP", "stdio transport", "SSE transport", "destructiveHint", "readOnlyHint"],
      "keywordPatterns": ["\\bMCP\\b", "FastMCP\\(", "@mcp\\.tool"],
      "pathPatterns": ["src/mt5_mvp/(server|cli)\\.py", "\\.mcp\\.json"],
      "intentPatterns": [
        "(register|expose|add).*(tool|MCP)",
        "(stdio|sse|http).*transport"
      ]
    },
    "excludePatterns": []
  },
  "trading-safety": {
    "description": "Dry-run discipline, magic numbers, idempotent comments, CONFIRM_LIVE.",
    "triggers": {
      "keywords": ["dry-run", "dry_run", "MT5_DRY_RUN", "CONFIRM_LIVE", "magic number", "idempotency", "live trade", "live trading"],
      "keywordPatterns": ["CONFIRM[_ ]LIVE", "DRY[_ ]?RUN", "magic\\s*number"],
      "pathPatterns": ["\\.claude/hooks/live-trade-guard\\.sh", "src/mt5_mvp/trade\\.py"],
      "intentPatterns": [
        "(execute|place|send).*(live|real|production).*(trade|order)",
        "(disable|enable).*dry.?run",
        "(close|modify).*(position|order)"
      ]
    },
    "excludePatterns": []
  },
  "pytest-mt5": {
    "description": "Mocking the MetaTrader5 module, conftest patterns, integration test gating.",
    "triggers": {
      "keywords": ["pytest", "fixture", "monkeypatch", "MagicMock", "conftest", "integration test", "mocked MetaTrader5"],
      "keywordPatterns": ["\\bpytest\\b", "@pytest\\.fixture", "MT5_INTEGRATION"],
      "pathPatterns": ["tests/.*\\.py", "tests/conftest\\.py"],
      "intentPatterns": [
        "(write|add|create).*(test|spec)",
        "mock(ing)?.*(MT5|MetaTrader)"
      ]
    },
    "excludePatterns": []
  },
  "uv-python-tooling": {
    "description": "uv add/sync/run, lockfile policy, .python-version.",
    "triggers": {
      "keywords": ["uv", "uv sync", "uv run", "uv add", "pyproject.toml", "uv.lock", ".python-version"],
      "keywordPatterns": ["\\buv\\s+(sync|run|add|remove|lock|pip)\\b", "pyproject\\.toml"],
      "pathPatterns": ["pyproject\\.toml", "uv\\.lock", "\\.python-version"],
      "intentPatterns": [
        "(install|add|update).*(dependency|package)",
        "(setup|bootstrap).*(env|venv|environment)"
      ]
    },
    "excludePatterns": ["pip install", "poetry"]
  },
  "candlestick-strategy": {
    "description": "Momentum-candle pattern definition, entry/exit/sizing rules for XAUUSD.",
    "triggers": {
      "keywords": ["momentum candle", "XAUUSD", "gold", "engulfing", "pin bar", "ATR", "stop loss", "take profit", "RR"],
      "keywordPatterns": ["X\\s*A\\s*U\\s*U\\s*S\\s*D", "stop[- ]?loss", "take[- ]?profit"],
      "pathPatterns": ["docs/strategies/.*\\.md", "src/mt5_mvp/strategies/.*\\.py"],
      "intentPatterns": [
        "(design|build|describe).*strategy",
        "(buy|sell)\\s+(signal|setup)"
      ]
    },
    "excludePatterns": []
  },
  "momentum-candle": {
    "description": "Momentum-candle strategy: trigger thresholds, breakout/pullback/trend patterns, Fibonacci-based SL/TP for XAUUSD.",
    "triggers": {
      "keywords": ["momentum candle", "scan_momentum_setups", "fibonacci", "fib", "breakout", "pullback", "trend continuation", "1.27 extension", "23.6"],
      "keywordPatterns": ["momentum[ _-]candle", "fib\\.?\\s*(0\\.236|23\\.?6|1\\.27|127)"],
      "pathPatterns": ["src/mt5_mvp/strategies/.*\\.py", "docs/strategies/momentum-candle\\.md", "tests/test_momentum_candle\\.py"],
      "intentPatterns": [
        "(scan|find|look\\s+for).*(momentum|setup|signal)",
        "(any|new).*setup.*(XAUUSD|gold|H1|M15|M5)",
        "(plan|design|extend).*(detector|strategy|momentum)"
      ]
    },
    "excludePatterns": []
  },
  "mql5-ea-patterns": {
    "description": "MQL5 indicator and Expert Advisor patterns. Use when editing files under mql5/, fixing .mq5 compile errors, working with iCustom buffers, CTrade, or Strategy Tester.",
    "triggers": {
      "keywords": ["mql5", "MetaEditor", "iCustom", "CTrade", "Strategy Tester", "OnTick", "OnCalculate", "ENUM_ORDER_TYPE", ".mq5", ".mqh", ".ex5"],
      "keywordPatterns": ["\\b(mq5|mqh|ex5)\\b", "iCustom\\s*\\(", "CTrade", "Strategy\\s+Tester"],
      "pathPatterns": ["mql5/.*\\.mq[h5]", "docs/mql5-indicators\\.md"],
      "intentPatterns": [
        "(write|edit|fix).*(indicator|expert advisor|EA|MQL)",
        "backtest.*(mql|expert|tester)",
        "compile.*(mq5|mqh)"
      ]
    },
    "excludePatterns": []
  }
}
