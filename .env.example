# MetaTrader 5 demo credentials
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=InstaForex-Server

# Path to terminal64.exe (Windows). Leave blank to auto-detect.
MT5_PATH=C:\Program Files\MetaTrader\terminal64.exe

# Connection timeout in seconds
MT5_TIMEOUT=60

# Safety guard. 1 = simulate trades, 0 = send live orders.
# When MT5_DRY_RUN=0, the prompt must include the literal token
# CONFIRM_LIVE for any destructive MCP tool to execute.
MT5_DRY_RUN=1

# Default magic number for orders placed by this MCP server.
# Used for idempotency / dedup. Override per signal as needed.
MT5_MAGIC=900001
